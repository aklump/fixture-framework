{
  "name": "aklump/fixture-framework",
  "description": "A PHP framework for discoverable, ordered fixtures that prepare application state for testing, development, and repeatable setup workflows.",
  "homepage": "https://github.com/aklump/fixture-framework",
  "authors": [
    {
      "name": "Aaron Klump",
      "homepage": "https://www.intheloftstudios.com",
      "role": "Senior Developer"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-ctype": "*"
  },
  "keywords": [
    "fixtures",
    "framework",
    "testing",
    "seeding"
  ],
  "autoload": {
    "psr-4": {
      "AKlump\\FixtureFramework\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AKlump\\FixtureFramework\\Tests\\": "./tests_phpunit/src/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  }
}
